# check=skip=InvalidDefaultArgInFrom
ARG BASE_IMAGE
FROM ${BASE_IMAGE} AS build

ENV DEBIAN_FRONTEND=noninteractive

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

WORKDIR /workspace

ARG PRODUCT
ARG DISTRO_FAMILY
ARG DISTRO
ARG BUILD_VERSION
ARG BUILD_REVISION=1
ARG TARGET_ARCH

ARG PODMAN_TAG
ARG UPSTREAM_SHA256

ARG NETAVARK_TAG
ARG NETAVARK_UPSTREAM_SHA256
ARG NETAVARK_VENDOR_SHA256

ARG AARDVARK_TAG
ARG AARDVARK_UPSTREAM_SHA256
ARG AARDVARK_VENDOR_SHA256

ARG RUST_VERSION

ARG CONTAINERS_COMMON_TAG
ARG CONTAINERS_COMMON_VERSION
ARG CONTAINERS_COMMON_ARCHIVE_SHA256

ARG CONTAINERS_STORAGE_TAG
ARG CONTAINERS_STORAGE_VERSION
ARG CONTAINERS_STORAGE_ARCHIVE_SHA256

COPY scripts /workspace/scripts
COPY packaging /workspace/packaging

RUN chmod +x /workspace/scripts/container/build.sh && \
    PRODUCT="${PRODUCT}" \
    DISTRO_FAMILY="${DISTRO_FAMILY}" \
    DISTRO="${DISTRO}" \
    BUILD_VERSION="${BUILD_VERSION}" \
    BUILD_REVISION="${BUILD_REVISION}" \
    TARGET_ARCH="${TARGET_ARCH}" \
    PODMAN_TAG="${PODMAN_TAG}" \
    UPSTREAM_SHA256="${UPSTREAM_SHA256}" \
    NETAVARK_TAG="${NETAVARK_TAG}" \
    NETAVARK_UPSTREAM_SHA256="${NETAVARK_UPSTREAM_SHA256}" \
    NETAVARK_VENDOR_SHA256="${NETAVARK_VENDOR_SHA256}" \
    AARDVARK_TAG="${AARDVARK_TAG}" \
    AARDVARK_UPSTREAM_SHA256="${AARDVARK_UPSTREAM_SHA256}" \
    AARDVARK_VENDOR_SHA256="${AARDVARK_VENDOR_SHA256}" \
    RUST_VERSION="${RUST_VERSION}" \
    CONTAINERS_COMMON_TAG="${CONTAINERS_COMMON_TAG}" \
    CONTAINERS_COMMON_VERSION="${CONTAINERS_COMMON_VERSION}" \
    CONTAINERS_COMMON_ARCHIVE_SHA256="${CONTAINERS_COMMON_ARCHIVE_SHA256}" \
    CONTAINERS_STORAGE_TAG="${CONTAINERS_STORAGE_TAG}" \
    CONTAINERS_STORAGE_VERSION="${CONTAINERS_STORAGE_VERSION}" \
    CONTAINERS_STORAGE_ARCHIVE_SHA256="${CONTAINERS_STORAGE_ARCHIVE_SHA256}" \
    /workspace/scripts/container/build.sh

FROM scratch AS artifact-export

COPY --from=build /out/ /
