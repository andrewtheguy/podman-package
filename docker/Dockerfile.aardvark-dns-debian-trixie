FROM debian:trixie AS base

ENV DEBIAN_FRONTEND=noninteractive

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    devscripts \
    dpkg-dev \
    equivs \
    fakeroot \
    gnupg \
    jq \
    patch \
    quilt \
    tar \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

FROM base AS build

ARG DISTRO=trixie
ARG BUILD_VERSION
ARG BUILD_REVISION=1
ARG AARDVARK_TAG
ARG AARDVARK_UPSTREAM_SHA256
ARG AARDVARK_VENDOR_SHA256
ARG RUST_VERSION
ARG TARGET_ARCH

COPY scripts/lib/common.sh /workspace/scripts/lib/common.sh
COPY scripts/container/in-container-build-aardvark-dns-debian-trixie.sh /workspace/scripts/container/in-container-build-aardvark-dns-debian-trixie.sh
COPY packaging/patches-aardvark-dns-debian-trixie /workspace/packaging/patches-aardvark-dns-debian-trixie

RUN chmod +x /workspace/scripts/container/in-container-build-aardvark-dns-debian-trixie.sh && \
    DISTRO="${DISTRO}" \
    BUILD_VERSION="${BUILD_VERSION}" \
    BUILD_REVISION="${BUILD_REVISION}" \
    AARDVARK_TAG="${AARDVARK_TAG}" \
    AARDVARK_UPSTREAM_SHA256="${AARDVARK_UPSTREAM_SHA256}" \
    AARDVARK_VENDOR_SHA256="${AARDVARK_VENDOR_SHA256}" \
    RUST_VERSION="${RUST_VERSION}" \
    TARGET_ARCH="${TARGET_ARCH}" \
    /workspace/scripts/container/in-container-build-aardvark-dns-debian-trixie.sh

FROM scratch AS artifact-export

COPY --from=build /out/ /
