FROM debian:trixie AS base

ENV DEBIAN_FRONTEND=noninteractive

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    devscripts \
    dpkg-dev \
    equivs \
    fakeroot \
    gnupg \
    jq \
    patch \
    quilt \
    tar \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

FROM base AS build

ARG DISTRO=trixie
ARG BUILD_VERSION
ARG BUILD_REVISION=1
ARG CONTAINERS_STORAGE_TAG
ARG CONTAINERS_STORAGE_VERSION
ARG CONTAINERS_STORAGE_ARCHIVE_SHA256
ARG TARGET_ARCH

COPY scripts/lib/common.sh /workspace/scripts/lib/common.sh
COPY scripts/container/in-container-build-containers-storage-debian-trixie.sh /workspace/scripts/container/in-container-build-containers-storage-debian-trixie.sh
COPY packaging/patches-containers-storage-debian-trixie /workspace/packaging/patches-containers-storage-debian-trixie

RUN chmod +x /workspace/scripts/container/in-container-build-containers-storage-debian-trixie.sh && \
    DISTRO="${DISTRO}" \
    BUILD_VERSION="${BUILD_VERSION}" \
    BUILD_REVISION="${BUILD_REVISION}" \
    CONTAINERS_STORAGE_TAG="${CONTAINERS_STORAGE_TAG}" \
    CONTAINERS_STORAGE_VERSION="${CONTAINERS_STORAGE_VERSION}" \
    CONTAINERS_STORAGE_ARCHIVE_SHA256="${CONTAINERS_STORAGE_ARCHIVE_SHA256}" \
    TARGET_ARCH="${TARGET_ARCH}" \
    /workspace/scripts/container/in-container-build-containers-storage-debian-trixie.sh

FROM scratch AS artifact-export

COPY --from=build /out/ /
