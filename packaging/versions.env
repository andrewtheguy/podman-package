# Pinned versions for upstream inputs.
# The shared build scripts source this file directly.

# Podman (Go)
PODMAN_TAG=v6.0.0
UPSTREAM_SHA256=f35ac7c40f0fd01bfedfe627c23ff7a577b071d50f2b0726e4734d51810f5a7d

# netavark (Rust) — network stack required by Podman 6.0.
# NETAVARK_UPSTREAM_SHA256: sha256 of the GitHub source archive tarball.
# NETAVARK_VENDOR_SHA256:   sha256 of the release vendored-deps tarball.
# RUST_VERSION:             pinned Rust toolchain (>= netavark MSRV) installed in-container.
NETAVARK_TAG=v2.0.0
NETAVARK_UPSTREAM_SHA256=031aeeacc930382e8635d40a885798eff1da164dfcf9024b698f822e5995d9c8
NETAVARK_VENDOR_SHA256=86de7eb3a4e9ecc4acd5addc462879e8f2bac3562a4b99f12a4be67e5218c2cb
RUST_VERSION=1.88.0

# aardvark-dns (Rust) — DNS server required by Podman 6.0 / netavark.
# Reuses the shared RUST_VERSION above.
# AARDVARK_UPSTREAM_SHA256: sha256 of the GitHub source archive tarball.
# AARDVARK_VENDOR_SHA256:   sha256 of the release vendored-deps tarball.
AARDVARK_TAG=v2.0.0
AARDVARK_UPSTREAM_SHA256=d3f5d6b3be3c2d80e8257fb9467e34ff104f299474427979454034dca6dc88cc
AARDVARK_VENDOR_SHA256=c5ca49d98c535fa3c8d0d195512faf1f8610ad9ca4f62bec73c7bbfc4ddcc0b6

# containers-common (config files)
# Provides /etc/containers + /usr/share/containers config matching Podman 6.0.
# Source lives in the containers/container-libs monorepo under the common/ subdir;
# the tag is "common/v<VERSION>". Produces an Architecture: all package (no compile).
# CONTAINERS_COMMON_ARCHIVE_SHA256: sha256 of the GitHub container-libs tag archive.
CONTAINERS_COMMON_TAG=common/v0.68.0
CONTAINERS_COMMON_VERSION=0.68.0
CONTAINERS_COMMON_ARCHIVE_SHA256=61391b67e58ecffe4aae8ed620f35c57098b612d0b602d640ad541fb24b06908

# containers-storage (CLI + storage.conf)
# Its storage.conf has graphroot/runroot commented out, which fixes rootless
# Podman 6.0 (storage lib v1.63.0 honors an explicit graphroot even rootless).
# Source: containers/container-libs monorepo, storage/ subdir, tag "storage/v<VERSION>".
# Compiled Go (CGO); the Go toolchain version is derived from upstream go.mod.
# CONTAINERS_STORAGE_ARCHIVE_SHA256: sha256 of the GitHub container-libs tag archive.
CONTAINERS_STORAGE_TAG=storage/v1.63.0
CONTAINERS_STORAGE_VERSION=1.63.0
CONTAINERS_STORAGE_ARCHIVE_SHA256=3a0f119a5abb11ff45e49793243278075c5ab5c409dd93ef5106aa443b410fc7
